<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✏️  Saber Notes"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FF111827"
        android:paddingBottom="8dp"/>

    <TextView android:id="@+id/note_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#FF374151"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView android:id="@+id/note_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#FF374151"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView android:id="@+id/note_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#FF374151"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView android:id="@+id/note_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#FF374151"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView android:id="@+id/note_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#FF374151"
        android:maxLines="1"
        android:ellipsize="end"/>

</LinearLayout>
